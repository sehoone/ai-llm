# =============================================================
# mcp-full 통합 배포 환경 변수
# cp .env.example .env 후 값을 채워주세요.
# =============================================================

# ── Database ──────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=change-me-strong-password   # 필수 변경

PLATFORM_DB=llm_db        # platform-server 가 사용하는 DB명
MCP_DB=sample_db          # spring-ai-mcp 가 사용하는 DB명

# ── platform-server ───────────────────────────────────────────
# JWT 서명 시크릿키 (32자 이상) — 생성: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-strong-secret-key-at-least-32chars!!

JWT_ACCESS_MINUTES=10        # access 토큰 만료 (분)
JWT_REFRESH_MINUTES=10080    # refresh 토큰 만료 (분, 기본 7일)

PLATFORM_PORT=8080           # 외부 노출 포트 (직접 접근용, Nginx 경유 시 불필요)

# ── spring-ai-mcp ─────────────────────────────────────────────
MCP_PORT=8081                # 외부 노출 포트 (직접 접근용, Nginx 경유 시 불필요)

TODO_API_URL=https://jsonplaceholder.typicode.com   # SampleTool 외부 API

# ── admin-front ───────────────────────────────────────────────
ADMIN_PORT=3000              # 외부 노출 포트 (직접 접근용, Nginx 경유 시 불필요)

# ── nginx ─────────────────────────────────────────────────────
NGINX_PORT=80                # 단일 진입점 포트

# 브라우저에서 platform-server 에 접근하는 주소 (빌드 시 JS 번들에 포함됨)
# Nginx 경유: http://YOUR_SERVER_IP          (포트 불필요)
# 직접 접근:  http://YOUR_SERVER_IP:8080
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP
