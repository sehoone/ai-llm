# mcp-platform 이 먼저 기동되어 있어야 합니다 (네트워크 생성 필요)
APP_NETWORK=mcp-platform-net

# Grafana 관리자 비밀번호 (필수)
GRAFANA_PASSWORD=change-me-secure-password

# Grafana 포트 (기본 3001 — admin-front 3000과 충돌 방지)
GRAFANA_PORT=3001

# Prometheus 포트
PROMETHEUS_PORT=9090

# 도메인 (리버스 프록시 사용 시)
GRAFANA_DOMAIN=localhost

# 알림 이메일 (선택)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alert@example.com
