# PostgreSQL
DB_NAME=sample_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# DB 접속 URL
# 내장 PostgreSQL 사용 시 (--profile db): jdbc:postgresql://postgres:5432/<DB_NAME>
# 외부 PostgreSQL 사용 시: jdbc:postgresql://<host>:<port>/<dbname>
DB_URL=jdbc:postgresql://postgres:5432/sample_db

# JWT 서명 검증용 시크릿키 (Base64, 256비트 이상) — openssl rand -base64 32
JWT_SECRET=

# 외부 Todo API URL
TODO_API_URL=https://jsonplaceholder.typicode.com

# 앱 포트 (기본값: 8080)
PORT=8080
