# PostgreSQL
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# DB 접속 URL
# 내장 PostgreSQL 사용 시 (--profile db): jdbc:postgresql://postgres:5432/<DB_NAME>
# 외부 PostgreSQL 사용 시: jdbc:postgresql://<host>:<port>/<dbname>
DB_URL=

# platform-server 주소 (API 키 검증 요청 대상)
PLATFORM_URL=

# 외부 Todo API URL
TODO_API_URL=

# 앱 포트 (기본값: 8080)
PORT=8080
