# Application
APP_ENV=local
SERVER_PORT=8080

# PostgreSQL (orchestrator-server와 동일 DB, 동일 스키마)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SCHEMA=llmonl

# JWT (orchestrator-server의 JWT_SECRET_KEY와 반드시 동일한 값)
JWT_SECRET_KEY=your_jwt_secret_key_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
