# Environment Configuration Example

# Application Settings
APP_ENV=production
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=false

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000,http://{서버ip}:8060"

# Langfuse Settings (앱 → Langfuse 연결)
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="http://langfuse:3000"
LANGFUSE_ENABLED=true

# Langfuse 서버 설정 (docker-compose langfuse 서비스용)
# 아래 값들은 배포 전 반드시 변경하세요
LANGFUSE_NEXTAUTH_URL="http://localhost:8067"
LANGFUSE_NEXTAUTH_SECRET="a3f8c2e1d4b5a6f7e8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1"
LANGFUSE_SALT="change-me-random-salt"
LANGFUSE_ENCRYPTION_KEY="change-me-must-be-64-hex-chars-long-0000000000000000000000000000"

# LLM Settings
OPENAI_API_KEY="
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.2

# Long-term Memory Settings (mem0)
LONG_TERM_MEMORY_MODEL=gpt-4o-mini
LONG_TERM_MEMORY_EMBEDDER_MODEL=text-embedding-3-small

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_SCHEMA=llmonl

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
