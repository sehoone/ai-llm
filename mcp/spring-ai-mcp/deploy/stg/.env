# PostgreSQL
DB_NAME=sample_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Keycloak (외부 서버 또는 별도 배포)
# 예: https://keycloak.example.com/realms/mcp
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/mcp
KEYCLOAK_CLIENT_ID=mcp-client

# 외부 Todo API URL
TODO_API_URL=https://jsonplaceholder.typicode.com

# 앱 포트 (기본값: 8080)
PORT=8080
