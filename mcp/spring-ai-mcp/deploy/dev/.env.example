DB_NAME=sample_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# 내장 PostgreSQL 사용 시 (--profile db): 아래 값 그대로 사용
# 외부 PostgreSQL 사용 시: 아래 DB_URL을 실제 주소로 변경
DB_URL=jdbc:postgresql://postgres:5432/sample_db

# JWT 서명 검증용 시크릿키 (Base64, 256비트 이상) — openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-base64-encoded-secret

TODO_API_URL=https://jsonplaceholder.typicode.com
PORT=8080
