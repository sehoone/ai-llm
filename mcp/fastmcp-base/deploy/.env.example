# ── API 키 ────────────────────────────────────────────────────────────────────
# demo_key 유지 시 샘플 데이터 반환 (실제 API 키 불필요)
OPENWEATHER_API_KEY=demo_key
NEWS_API_KEY=demo_key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# docker-compose 내부 네트워크에서 서비스명(postgres)을 호스트로 사용
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/fastmcp_db

# ── MCP 서버 ──────────────────────────────────────────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# 실행할 서버: integrated | weather | news | database
SERVER_TYPE=integrated

# ── JWT 인증 (streamable-http 전용) ──────────────────────────────────────────
# 반드시 변경: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
# "username:password,username2:password2" 형식
AUTH_USERS=admin:change_me_password

# ── 로깅 ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 포트 오버라이드 (선택) ────────────────────────────────────────────────────
# POSTGRES_PORT=5432
# PGADMIN_PORT=5050

# ── pgAdmin (--profile admin 시 사용) ────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
