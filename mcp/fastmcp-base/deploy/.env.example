# ============================================================
# deploy/.env.example — Docker 배포용 환경변수 템플릿
# cp .env.example .env
#
# Docker는 환경변수를 직접 주입하므로 APP_ENV 파일 분리 방식과 무관하게
# 이 파일의 값이 그대로 적용됩니다.
# ============================================================

# ── 외부 API ─────────────────────────────────────────────────
# demo_key 유지 시 샘플 데이터 반환 (실제 API 키 불필요)
OPENWEATHER_API_KEY=demo_key
NEWS_API_KEY=demo_key

# ── PostgreSQL ────────────────────────────────────────────────
# docker-compose 내부 네트워크에서 서비스명(postgres)을 호스트로 사용
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/fastmcp_db

# ── MCP 서버 ─────────────────────────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
# workers > 1 은 CPU 바운드 작업에 유리. 비동기 전용이면 1로 충분
MCP_WORKERS=1

# ── JWT 인증 ─────────────────────────────────────────────────
# 반드시 변경: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# 비밀번호는 평문 또는 bcrypt 해시 모두 지원
# 해시 생성: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
AUTH_USERS=admin:change_me_password

DOMAIN=your-domain.com
# https (기본) 또는 http — http 선택 시 SSL 인증서 불필요
NGINX_MODE=https

# ── 로깅 ─────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 포트 오버라이드 (선택) ────────────────────────────────────
# POSTGRES_PORT=5432

# ── Grafana (--profile monitoring 시 사용) ────────────────────
# 반드시 변경
GRAFANA_PASSWORD=change_me
GRAFANA_PORT=3000
