# ============================================================
# deploy/.env.prd — 프로덕션 환경변수
# 절대 git 커밋 금지
#
# 필수 변경 항목:
#   POSTGRES_PASSWORD, DATABASE_URL, JWT_SECRET_KEY, AUTH_USERS, DOMAIN
# ============================================================

# ── 외부 API ─────────────────────────────────────────────────
# 실제 API 키로 교체. demo_key 유지 시 샘플 데이터만 반환됨
OPENWEATHER_API_KEY=demo_key
NEWS_API_KEY=demo_key

# ── PostgreSQL ────────────────────────────────────────────────
# docker-compose 내부 네트워크에서 서비스명(postgres)을 호스트로 사용
# POSTGRES_PASSWORD와 DATABASE_URL의 비밀번호는 반드시 일치
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/fastmcp_db

# ── MCP 서버 ─────────────────────────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_WORKERS=1

# ── JWT 인증 ─────────────────────────────────────────────────
# 생성: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# 비밀번호는 평문 또는 bcrypt 해시 모두 지원
# 해시 생성: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
AUTH_USERS=admin:change_me_password

# ── 도메인 / Nginx ────────────────────────────────────────────
DOMAIN=your-domain.com
# https (기본) 또는 http — deploy.sh 인수로도 덮어쓸 수 있음
NGINX_MODE=https
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── 로깅 ─────────────────────────────────────────────────────
LOG_LEVEL=WARNING

# ── Grafana (--profile monitoring 시 사용) ────────────────────
# 반드시 변경
GRAFANA_PASSWORD=change_me
GRAFANA_PORT=3000
