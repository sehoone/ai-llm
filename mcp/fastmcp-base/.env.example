# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# API 키가 없으면 demo_key 로 두면 데모 데이터가 반환됩니다.

# OpenWeatherMap API 키 — https://openweathermap.org/api
OPENWEATHER_API_KEY=demo_key

# NewsAPI 키 — https://newsapi.org
NEWS_API_KEY=demo_key

# PostgreSQL 연결 문자열
# 형식: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/fastmcp_db

# HTTP 클라이언트 설정 (선택사항)
# HTTP_TIMEOUT=10.0
# HTTP_MAX_RETRIES=3

# 데이터베이스 페이지네이션 (선택사항)
# DB_PAGE_SIZE=10
# DB_MAX_PAGE_SIZE=100
# CONTENT_PREVIEW_LENGTH=200

# 로깅 레벨: DEBUG | INFO | WARNING | ERROR (선택사항)
# LOG_LEVEL=INFO

# MCP 서버 Transport: stdio | streamable-http (선택사항)
# MCP_TRANSPORT=streamable-http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# JWT 인증 (HTTP transport 전용)
# 프로덕션: openssl rand -hex 32 로 생성
# JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 인증 사용자 목록 — "username:password" 쉼표 구분
# AUTH_USERS=admin:secret,viewer:pass123
