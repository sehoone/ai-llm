# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings
OPENAI_API_KEY="change-me-openai-api-key" # e.g. OpenAI API key
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.2

# Auth Mode: "jwt" (HS256 공유 비밀키) | "keycloak" (RS256 JWKS)
# APP_ENV=development/test → 기본값 jwt
# APP_ENV=staging/production → 기본값 keycloak
# 명시적으로 지정하면 아래 값이 우선 적용됨
# AUTH_MODE=jwt

# JWT Settings (AUTH_MODE=jwt 일 때 사용)
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Keycloak Settings (AUTH_MODE=keycloak 일 때 사용)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=llm-platform
KEYCLOAK_CLIENT_ID=orchestrator-app
KEYCLOAK_CLIENT_SECRET=orchestrator-secret
# KEYCLOAK_TOKEN_AUDIENCE=  # 비어있으면 audience 검증 건너뜀
KEYCLOAK_JWKS_CACHE_TTL=3600

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_SCHEMA=llmonl

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
