<clickhouse>
    <!-- Single-node cluster definition for Langfuse v3 -->
    <remote_servers replace="true">
        <default>
            <shard>
                <replica>
                    <host>clickhouse</host>
                    <port>9000</port>
                    <user>default</user>
                    <password>clickhouse</password>
                </replica>
            </shard>
        </default>
    </remote_servers>

    <!-- Macros for ReplicatedMergeTree -->
    <macros>
        <shard>1</shard>
        <replica>clickhouse-1</replica>
    </macros>

    <!-- Built-in ClickHouse Keeper (replaces ZooKeeper) -->
    <keeper_server>
        <tcp_port>2181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>clickhouse</hostname>
                <port>9444</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <!-- ZooKeeper pointing to built-in Keeper -->
    <zookeeper>
        <node>
            <host>clickhouse</host>
            <port>2181</port>
        </node>
    </zookeeper>
</clickhouse>
