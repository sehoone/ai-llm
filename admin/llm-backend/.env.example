# ─── App ────────────────────────────────────────────────────────────────────
APP_PORT=8080

# ─── Database ────────────────────────────────────────────────────────────────
DB_NAME=llmbackend
DB_USERNAME=llmuser
DB_PASSWORD=change-me-strong-password
DB_EXTERNAL_PORT=5432

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Base64로 인코딩된 256-bit 이상의 시크릿 키 (openssl rand -base64 64 로 생성 권장)
JWT_SECRET=replace-with-your-very-long-base64-encoded-secret-key
JWT_ACCESS_TOKEN_EXPIRY=1800000    # 30분 (ms)
JWT_REFRESH_TOKEN_EXPIRY=604800000 # 7일 (ms)
